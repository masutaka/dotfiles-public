{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Bash(bundle info:*)",
      "Bash(find:*)",
      "Bash(ghro:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(rg:*)",
      "Read(.env.example)",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(nc:*)",
      "Bash(rm -rf .git)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(sudo:*)",
      "Bash(wget:*)",
      "Read(.env)",
      "Read(.envrc)",
      "Write(.env*)"
    ]
  },
  "enableAllProjectMcpServers": false,
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.js"
  }
}
