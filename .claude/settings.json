{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Bash(bundle info:*)",
      "Bash(find:*)",
      "Bash(ghro:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(mkdir:*)",
      "Bash(rg:*)",
      "Read(.env.example)",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id"
    ],
    "deny": [
      "Bash(git add --all:*)",
      "Bash(git add -A:*)",
      "Bash(git add .:*)",
      "Bash(git commit --amend:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git commit -n:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(nc:*)",
      "Bash(rm -rf .git)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(sudo:*)",
      "Bash(wget:*)",
      "Read(.env)",
      "Read(.envrc)",
      "Write(.env*)"
    ],
    "ask": [
      "Bash(curl:*)",
      "Bash(git push:*)"
    ]
  },
  "enableAllProjectMcpServers": false,
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.js"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/tmux-spinner.sh start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/git-guard.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/tmux-spinner.sh heartbeat"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/tmux-spinner.sh heartbeat"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *.md) mo \"$f\" </dev/null ;; esac; } 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/macos-notify.sh Funk"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/tmux-spinner.sh notify"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/macos-notify.sh Glass"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/tmux-spinner.sh stop"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/tmux-spinner.sh stop"
          }
        ]
      }
    ]
  }
}
