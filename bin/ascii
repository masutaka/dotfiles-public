#!/bin/sh

# ASCII コード表の 0x22, 0x27 に対応する全角記号 (”, ’) を
# ヒアドキュメント内にそのまま含むため、SC1111 を抑制する。
# shellcheck disable=SC1111

ESC=$(printf '\033')
H="${ESC}[44;97m"   # 行ヘッダ: 青背景 + 白文字
R="${ESC}[31m"      # 制御文字/未定義領域: 赤
D="${ESC}[2m"       # クレジット: 薄字
N="${ESC}[m"        # リセット

cat << EOF

  ${H}   00 01 02 03 04 05 06 07 08 09 0A 0B 0C 0D 0E 0F${N}
  ${H}00${N} ${R}nl sh sx ex et eq ak bl bs ht lf vt ff cr so si${N}
  ${H}10${N} ${R}de d1 d2 d3 d4 ak sn eb cn em sb ec fs gs rs us${N}
  ${H}20${N} ${R}sp ${N}！ ” ＃ ＄ ％ ＆ ’ （ ） ＊ ＋ ， − ． ／
  ${H}30${N} ０ １ ２ ３ ４ ５ ６ ７ ８ ９ ： ； ＜ ＝ ＞ ？
  ${H}40${N} ＠ Ａ Ｂ Ｃ Ｄ Ｅ Ｆ Ｇ Ｈ Ｉ Ｊ Ｋ Ｌ Ｍ Ｎ Ｏ
  ${H}50${N} Ｐ Ｑ Ｒ Ｓ Ｔ Ｕ Ｖ Ｗ Ｘ Ｙ Ｚ ［ ￥ ］ ＾ ＿
  ${H}60${N} ｀ ａ ｂ ｃ ｄ ｅ ｆ ｇ ｈ ｉ ｊ ｋ ｌ ｍ ｎ ｏ
  ${H}70${N} ｐ ｑ ｒ ｓ ｔ ｕ ｖ ｗ ｘ ｙ ｚ ｛ ｜ ｝ ￣ ${R}dl${N}
  ${H}80${N} ${R}-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- --${N}
  ${H}90${N} ${R}-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- --${N}
  ${H}A0${N} ${R}--${N} 。 「 」 、 ・ ヲ ァ ィ ゥ ェ ォ ャ ュ ョ ッ
  ${H}B0${N} ー ア イ ウ エ オ カ キ ク ケ コ サ シ ス セ ソ
  ${H}C0${N} タ チ ツ テ ト ナ ニ ヌ ネ ノ ハ ヒ フ ヘ ホ マ
  ${H}D0${N} ミ ム メ モ ヤ ユ ヨ ラ リ ル レ ロ ワ ン ゛ ゜
  ${H}E0${N} ${R}-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- --${N}
  ${H}F0${N} ${R}-- -- -- -- -- -- -- -- -- -- -- ${D}by H.Yamagishi${N}

EOF

### End of file
