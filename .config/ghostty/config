# "-" ">" などのプログラミング合字を無効化（→ のように表示されるのを防ぐ）
# プログラミング合字は主に calt で実装されているため、dlig だけでは不十分
font-feature = -calt
font-feature = -dlig
font-feature = -liga

font-size = 12.0

# 入力中はマウスカーソルを非表示にする
mouse-hide-while-typing = true

# 左 Option キーを Meta キーとして使用する。
macos-option-as-alt = left

theme = Terminal Basic Dark
